    <script>
        let currentPhase = 0;

        function showPhase(phaseIndex) {
            // Hide all phases
            document.querySelectorAll('.phase-content').forEach(phase => {
                phase.classList.remove('active');
            });

            // Deactivate all buttons
            document.querySelectorAll('.phase-btn').forEach(btn => {
                btn.classList.remove('active');
            });

            // Show selected phase
            document.getElementById(`phase${phaseIndex}`).classList.add('active');
            document.querySelectorAll('.phase-btn')[phaseIndex].classList.add('active');
            
            currentPhase = phaseIndex;

            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function updateProgress() {
            const checkboxes = document.querySelectorAll('.task-checkbox');
            const totalTasks = checkboxes.length;
            const completedTasks = Array.from(checkboxes).filter(cb => cb.checked).length;
            
            // Update completed count
            document.getElementById('completedCount').textContent = `${completedTasks} / ${totalTasks}`;
            
            // Update progress bar
            const progressPercent = (completedTasks / totalTasks) * 100;
            document.getElementById('totalProgress').style.width = `${progressPercent}%`;
            
            // Save to localStorage
            const taskStates = Array.from(checkboxes).map(cb => cb.checked);
            localStorage.setItem('payrollTaskProgress', JSON.stringify(taskStates));
        }

        // Load saved progress on page load
        window.addEventListener('DOMContentLoaded', () => {
            const savedProgress = localStorage.getItem('payrollTaskProgress');
            if (savedProgress) {
                const taskStates = JSON.parse(savedProgress);
                const checkboxes = document.querySelectorAll('.task-checkbox');
                taskStates.forEach((checked, index) => {
                    if (checkboxes[index]) {
                        checkboxes[index].checked = checked;
                    }
                });
                updateProgress();
            }
        });
    </script>
</body>
</html>
